{
  "id": "test",
  "name": "用户表单",
  "appendHead": "<script>\nfunction myBeforeSubmit() {\n    console.log('准备提交');\n    return true; // 返回 false 可以阻止提交\n}\n\nfunction mySuccessHandler(res) {\n    console.log('提交成功', res);\n    layer.msg('保存成功！');\n}\n\nfunction myErrorHandler(xhr, status, error) {\n    console.error('提交失败', error);\n    layer.msg('保存失败！');\n}</script>",
  "dataSource": "dataSource",
  "initExpress":
  [
    "StringBuilder sql=new StringBuilder(); ",
    "sql.append(\"   select a.students_id ID ,a.ruxue_date RUXUE_DATE, a.useremail USER_EMAIL,a.username USER_NAME,a.usersex USER_SEX,a.area_id AREA_ID, a.add_time ADD_TIME,group_concat(c.hobbys_id) HOBBYS_IDS from students a left join  rel_students_hobbys rh on rh.students_id=a.students_id left join hobbys c on rh.hobbys_id=c.hobbys_id   where  a.delete_flag=0 and a.students_id=#{ID}\"); return selectOne(sql);"
  ],
  "submitExpress": [
    "import top.ezadmin.plugins.express.jdbc.UpdateParam;",
    "import top.ezadmin.plugins.express.jdbc.InsertParam;",
    "if(isBlank(\"ID\")){",
    "    param=new InsertParam();",
    "    param.table(\"students\");",
    "    param.add( \"#{students_id}\");",
    "    param.add( \"#{username}\");",
    "    param.add( \"#{useremail}\");",
    "    param.add( \"#{usersex,jdbcType=NUMBER}\");",
    "    param.add( \"#{area_id,jdbcType=NUMBER}\");",
    "    param.add( \"#{ruxue_date,jdbcType=DATE}\");",
    "    param.add( \"#{delete_flag,value=0,jdbcType=NUMBER}\");",
    "    id=insertSimple(param);",

    "    return id;",
    "}else{",
    "    param=new UpdateParam();",
    "    param.table(\"students\");",
    "    param.add( \"#{username}\");",
    "    param.add(     \"#{useremail}\");",
    "    param.add( \"#{usersex,jdbcType=NUMBER}\");",
    "    param.add( \"#{area_id,jdbcType=NUMBER}\");",
    "    param.add( \"#{ruxue_date,jdbcType=DATE}\");",
    "    param.where(\" where students_id=#{ID} \");",
    "    updateSimple(param);",
    "    return $(\"ID\");",
    "}"
  ],
  "deleteExpress": ["update(\"UPDATE students set delete_flag=1 where students_id=#{ID}\");"],
  "statusExpress": ["update(\"UPDATE students set delete_flag=1 where students_id=#{ID}\");"],
