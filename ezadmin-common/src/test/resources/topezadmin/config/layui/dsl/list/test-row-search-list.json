{
  "id": "test-row-search-list",
  "title": "测试二维数组搜索布局列表",
  "description": "测试新的二维数组search格式，每行默认4个搜索字段",
  "dataSource": "dataSource",
  "body": {
    "emptyShow": "-",
    "showIndex": true,
    "selectable": true,
    "rowActionWidth": 175
  },
  "search": [
    [
      {
        "name": "NAME",
        "label": "姓名",
        "component": "input",
        "operator": "like",
        "props": {
          "placeholder": "请输入姓名"
        }
      },
      {
        "name": "AGE",
        "label": "年龄",
        "component": "input",
        "operator": "eq",
        "props": {
          "type": "number",
          "placeholder": "请输入年龄"
        }
      },
      {
        "name": "STATUS",
        "label": "状态",
        "component": "select",
        "operator": "eq",
        "initData": {
          "dataJson": [
            {"label": "全部", "value": ""},
            {"label": "启用", "value": "1"},
            {"label": "禁用", "value": "0"}
          ]
        },
        "props": {
          "placeholder": "请选择状态"
        }
      },
      {
        "name": "EMAIL",
        "label": "邮箱",
        "component": "input",
        "operator": "like",
        "props": {
          "placeholder": "请输入邮箱"
        }
      }
    ],
    [
      {
        "name": "CREATE_TIME",
        "label": "创建时间",
        "component": "date",
        "operator": "between",
        "props": {
          "placeholder": "请选择时间范围",
          "range": true
        }
      },
      {
        "name": "DEPT_ID",
        "label": "部门",
        "component": "select",
        "operator": "eq",
        "initData": {
          "dataJson": [
            {"label": "技术部", "value": "1"},
            {"label": "市场部", "value": "2"},
            {"label": "运营部", "value": "3"}
          ]
        },
        "props": {
          "placeholder": "请选择部门"
        }
      },
      {
        "name": "PHONE",
        "label": "手机号",
        "component": "input",
        "operator": "like",
        "props": {
          "placeholder": "请输入手机号"
        }
      }
    ]
  ],
  "column": [
    {
      "name": "ID",
      "label": "ID",
      "component": "tdText",
      "props": {
        "width": 80,
        "fixed": "left"
      }
    },
    {
      "name": "NAME",
      "label": "姓名",
      "component": "tdText",
      "props": {
        "width": 120
      }
    },
    {
      "name": "AGE",
      "label": "年龄",
      "component": "tdText",
      "props": {
        "width": 80
      }
    },
    {
      "name": "EMAIL",
      "label": "邮箱",
      "component": "tdText",
      "props": {
        "width": 200
      }
    },
    {
      "name": "PHONE",
      "label": "手机号",
      "component": "tdText",
      "props": {
        "width": 150
      }
    },
    {
      "name": "STATUS",
      "label": "状态",
      "component": "tdSelect",
      "initData": {
        "dataJson": [
          {"label": "启用", "value": "1"},
          {"label": "禁用", "value": "0"}
        ]
      },
      "props": {
        "width": 100
      }
    },
    {
      "name": "DEPT_ID",
      "label": "部门",
      "component": "tdSelect",
      "initData": {
        "dataJson": [
          {"label": "技术部", "value": "1"},
          {"label": "市场部", "value": "2"},
          {"label": "运营部", "value": "3"}
        ]
      },
      "props": {
        "width": 120
      }
    },
    {
      "name": "CREATE_TIME",
      "label": "创建时间",
      "component": "tdText",
      "props": {
        "width": 180
      }
    }
  ],
  "tableButton": [
    {
      "name": "ADD",
      "label": "新增",
      "component": "button-normal",
      "props": {
        "opentype": "MODAL",
        "area": "80%,90%",
        "url": "/form/test-row-layout-form"
      }
    }
  ],
  "rowButton": [
    {
      "name": "EDIT",
      "label": "编辑",
      "component": "button-normal",
      "props": {
        "opentype": "MODAL",
        "area": "80%,90%",
        "url": "/form/test-row-layout-form?ID={{=d.ID}}"
      }
    },
    {
      "name": "DELETE",
      "label": "删除",
      "component": "button-normal",
      "props": {
        "opentype": "CONFIRM_AJAX",
        "url": "/form/test-row-layout-form/delete?ID={{=d.ID}}",
        "confirm": "确定要删除吗？"
      }
    }
  ],
  "express": {
    "main": "return search('SELECT ID, NAME, AGE, EMAIL, PHONE, STATUS, DEPT_ID, CREATE_TIME FROM t_user WHERE 1=1')",
    "orderBy": "order by ID DESC",
    "count": "SELECT COUNT(1) FROM t_user WHERE 1=1"
  }
}
