  "express": {
    "main": [ "StringBuilder sql=new StringBuilder(); sql.append(\"   select a.students_id ID ,a.ruxue_date RUXUE_DATE, a.useremail USER_EMAIL,a.username USER_NAME,a.usersex USER_SEX,a.area_id AREA_ID, a.add_time ADD_TIME,group_concat(c.hobbys_id) HOBBYS_IDS from students a left join  rel_students_hobbys rh on rh.students_id=a.students_id left join hobbys c on rh.hobbys_id=c.hobbys_id   where  a.delete_flag=0\"); return search(sql);"],
    "orderBy": " order by a.students_id   ",
    "groupBy": " group by a.students_id ",
    "count": ""
  },
