							"dataJson":"[{\"label\":\"足球\",\"value\":1},{\"label\":\"篮球\",\"value\":2},{\"label\":\"羽毛球\",\"value\":3},{\"label\":\"乒乓球\",\"value\":4}]",
							"propsJson":"{\"placeholder\":\"请选择爱好（可多选）\"}"
