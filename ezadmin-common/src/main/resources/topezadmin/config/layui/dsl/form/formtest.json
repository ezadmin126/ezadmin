							},
							"propsJson":"{\"placeholder\":\"请选择爱好（可多选）\"}"
						}
					]
				}
			]
		}
	],
	"initExpress":[
		"if(isNotBlank('students_id')) {",
		"  student = selectOne('SELECT * FROM students WHERE students_id=${students_id}');",
		"  hobbys = select('SELECT hobbys_id FROM rel_students_hobbys WHERE students_id=${students_id}');",
		"  certificates = select('SELECT certificate_id FROM rel_students_certificate WHERE students_id=${students_id}');",
		"  hobbysList = new ArrayList();",
		"  for(i=0; i<hobbys.size(); i++) {",
		"    hobbysList.add(hobbys.get(i).get('hobbys_id'));",
		"  }",
		"  certList = new ArrayList();",
		"  for(i=0; i<certificates.size(); i++) {",
		"    certList.add(certificates.get(i).get('certificate_id'));",
		"  }",
		"  student.put('hobbys_ids', hobbysList);",
		"  student.put('certificate_ids', certList);",
		"  return student;",
		"} else {",
		"  return null;",
		"}"
	],
	"submitExpress":[
		"if(!isNotBlank('students_id')) {",
		"  // 新增学生",
		"  param = new InsertParam();",
		"  param.table('students');",
		"  param.add('#{username}');",
		"  param.add('#{useremail}');",
		"  param.add('#{usersex}');",
		"  param.add('#{area_id}');",
		"  param.add('#{ruxue_date}');",
		"  param.add('#{delete_flag,value=0}');",
		"  param.add('#{add_time,value=NOW()}');",
		"  param.add('#{update_time,value=NOW()}');",
		"  insertSimple(param);",
		"  newId = selectOne('SELECT LAST_INSERT_ID() as id').get('id');",
		"  // 插入爱好关系",
		"  if(isNotBlank('hobbys_ids')) {",
		"    hobbyIds = $('hobbys_ids').split(',');",
		"    for(i=0; i<hobbyIds.length; i++) {",
		"      insert('INSERT INTO rel_students_hobbys(students_id, hobbys_id) VALUES('+newId+','+hobbyIds[i]+')');",
		"    }",
		"  }",
		"  // 插入证书关系",
		"  if(isNotBlank('certificate_ids')) {",
		"    certIds = $('certificate_ids').split(',');",
		"    for(i=0; i<certIds.length; i++) {",
		"      insert('INSERT INTO rel_students_certificate(students_id, certificate_id) VALUES('+newId+','+certIds[i]+')');",
		"    }",
		"  }",
		"} else {",
		"  // 更新学生",
		"  param = new UpdateParam();",
		"  param.table('students');",
		"  param.add('#{username}');",
		"  param.add('#{useremail}');",
		"  param.add('#{usersex}');",
		"  param.add('#{area_id}');",
		"  param.add('#{ruxue_date}');",
		"  param.add('#{update_time,value=NOW()}');",
		"  param.where('students_id=#{students_id}');",
		"  updateSimple(param);",
		"  // 删除旧的爱好关系",
		"  update('DELETE FROM rel_students_hobbys WHERE students_id=${students_id}');",
		"  // 插入新的爱好关系",
		"  if(isNotBlank('hobbys_ids')) {",
		"    hobbyIds = $('hobbys_ids').split(',');",
		"    for(i=0; i<hobbyIds.length; i++) {",
		"      insert('INSERT INTO rel_students_hobbys(students_id, hobbys_id) VALUES(${students_id},'+hobbyIds[i]+')');",
		"    }",
		"  }",
		"  // 删除旧的证书关系",
		"  update('DELETE FROM rel_students_certificate WHERE students_id=${students_id}');",
		"  // 插入新的证书关系",
		"  if(isNotBlank('certificate_ids')) {",
		"    certIds = $('certificate_ids').split(',');",
		"    for(i=0; i<certIds.length; i++) {",
		"      insert('INSERT INTO rel_students_certificate(students_id, certificate_id) VALUES(${students_id},'+certIds[i]+')');",
		"    }",
		"  }",
		"}"
	],
	"deleteExpress":[
		"update('UPDATE students SET delete_flag=1 WHERE students_id=${students_id}');"
	]
}